{
  "name": "infragpt-frontend",
  "version": "1.0.0",
  "description": "InfraGPT frontend API service",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit --testTimeout=10000",
    "lint": "eslint src/"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "!src/tracing.js"]
  },
  "dependencies": {
    "express": "4.18.2",
    "axios": "1.6.7",
    "prom-client": "15.1.0",
    "winston": "3.11.0",
    "cors": "2.8.5",
    "helmet": "7.1.0",
    "express-rate-limit": "7.1.5"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "nodemon": "3.0.3",
    "eslint": "8.56.0"
  }
}
